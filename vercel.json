{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://finedu-backend-i4fm.onrender.com/api/$1"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/pages/(.*)",
      "destination": "/frontend/pages/$1"
    },
    {
      "source": "/css/(.*)",
      "destination": "/frontend/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/frontend/js/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/assets/$1"
    },
    {
      "source": "/contact.html",
      "destination": "/frontend/contact.html"
    },
    {
      "source": "/privacy.html",
      "destination": "/frontend/privacy.html"
    },
    {
      "source": "/terms.html",
      "destination": "/frontend/terms.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/index.html"
    }
  ]
}
